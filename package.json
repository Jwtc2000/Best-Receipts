{
  "name": "receipts-express",
  "private": true,
  "version": "1.9.0",
  "description": "Scan receipts, organize expense reports, export polished PDFs.",
  "type": "module",
  "scripts": {
    "prepare-assets": "node scripts/copy-tesseract-assets.mjs",
    "predev": "npm run prepare-assets",
    "prebuild": "npm run prepare-assets",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "test": "vitest run"
  },
  "dependencies": {
    "@tesseract.js-data/eng": "^1.0.0",
    "idb": "^8.0.0",
    "jspdf": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "fake-indexeddb": "^6.2.5",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^4.1.10"
  }
}
